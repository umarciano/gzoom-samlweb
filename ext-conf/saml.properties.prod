#  GZOOM - SAML Properties - PRODUZIONE
#  ⚠️ SOSTITUIRE <DOMINIO_PROD> con il dominio reale di produzione
#  Esempio: https://gzoom.ospedalecardarelli.it

onelogin.saml2.strict = true
onelogin.saml2.debug = false

# Service Provider - Produzione
onelogin.saml2.sp.entityid = http://172.20.128.11:8080/gzoom-saml-web/metadata.jsp
onelogin.saml2.sp.assertion_consumer_service.url = http://172.20.128.11:8080/gzoom-saml-web/acs.jsp
onelogin.saml2.sp.assertion_consumer_service.binding = urn:oasis:names:tc:SAML:2.0:bindings:HTTP-POST
onelogin.saml2.sp.single_logout_service.url = http://172.20.128.11:8080/gzoom-saml-web/sls.jsp
onelogin.saml2.sp.single_logout_service.binding = urn:oasis:names:tc:SAML:2.0:bindings:HTTP-Redirect
onelogin.saml2.sp.nameidformat = urn:oasis:names:tc:SAML:1.1:nameid-format:unspecified
onelogin.saml2.sp.x509cert =
onelogin.saml2.sp.privatekey =

# Identity Provider - Cardarelli (stesso per tutti gli ambienti)
onelogin.saml2.idp.entityid = https://identity.ospedalecardarelli.it/realms/aurora
onelogin.saml2.idp.single_sign_on_service.url = https://identity.ospedalecardarelli.it/realms/aurora/protocol/saml
onelogin.saml2.idp.single_sign_on_service.binding = urn:oasis:names:tc:SAML:2.0:bindings:HTTP-Redirect
onelogin.saml2.idp.single_logout_service.url = https://identity.ospedalecardarelli.it/realms/aurora/protocol/saml
onelogin.saml2.idp.single_logout_service.response.url = https://identity.ospedalecardarelli.it/realms/aurora/protocol/saml
onelogin.saml2.idp.single_logout_service.binding = urn:oasis:names:tc:SAML:2.0:bindings:HTTP-Redirect
onelogin.saml2.idp.x509cert = 

# Security settings
onelogin.saml2.security.nameid_encrypted = false
onelogin.saml2.security.authnrequest_signed = false
onelogin.saml2.security.logoutrequest_signed = false
onelogin.saml2.security.logoutresponse_signed = false
onelogin.saml2.security.want_messages_signed = false
onelogin.saml2.security.want_assertions_signed = false
onelogin.saml2.security.sign_metadata =
onelogin.saml2.security.want_assertions_encrypted = false
onelogin.saml2.security.want_nameid_encrypted = false
onelogin.saml2.security.requested_authncontext = urn:oasis:names:tc:SAML:2.0:ac:classes:Password
onelogin.saml2.security.onelogin.saml2.security.requested_authncontextcomparison = exact
onelogin.saml2.security.allow_duplicated_attribute_name = false
onelogin.saml2.security.want_xml_validation = true
onelogin.saml2.security.signature_algorithm = http://www.w3.org/2001/04/xmldsig-more#rsa-sha256
onelogin.saml2.security.digest_algorithm = http://www.w3.org/2001/04/xmlenc#sha256
onelogin.saml2.security.reject_deprecated_alg = true

# Organization
onelogin.saml2.organization.name = AORN Cardarelli
onelogin.saml2.organization.displayname = AORN Antonio Cardarelli
onelogin.saml2.organization.url = http://172.20.128.11
onelogin.saml2.organization.lang = it

# Contacts
onelogin.saml2.contacts.technical.given_name = Amministratore
onelogin.saml2.contacts.technical.email_address = amministratore@ospedalecardarelli.it
onelogin.saml2.contacts.support.given_name = Supporto
onelogin.saml2.contacts.support.email_address = supporto@ospedalecardarelli.it

